# Required only if you want local, non-Codex LLM generation in your own extensions.
OPENAI_API_KEY=

# Optional but useful for Semantic Scholar's higher rate limits.
SEMANTIC_SCHOLAR_API_KEY=

# Optional advanced full-text/preprint discovery if you use Paperclip.
PAPERCLIP_API_KEY=

# Gmail SMTP sending. Use a Google app password, not your normal Google password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your.name@gmail.com
SMTP_PASSWORD=your_google_app_password
SMTP_FROM_NAME=Scientific Newsletter
